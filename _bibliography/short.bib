@inproceedings{su2017liplearner,
author = {Su, Zixiong and Fang, Shitao and Rekimoto, Jun},
title = {LipLearner: Customizing Silent Speech Commands from Voice Input Using One-Shot Lipreading},
year = {2022},
isbn = {9781450393218},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3526114.3558737},
doi = {10.1145/3526114.3558737},
abstract = {We present LipLearner, a lipreading-based silent speech interface that enables in-situ command customization on mobile devices. By leveraging contrastive learning to learn efficient representations from existing datasets, it performs instant fine-tuning for unseen users and words using one-shot learning. To further minimize the labor of command registration, we incorporate speech recognition to automatically learn new commands from voice input. Conventional lipreading systems provide limited pre-defined commands due to the time cost and user burden of data collection. In contrast, our technique provides expressive silent speech interaction with minimal data requirements. We conducted a pilot experiment to investigate the real-time performance of LipLearner, and the result demonstrates that an average accuracy of is achievable with only one training sample for each command.},
booktitle = {The Adjunct Publication of the 35th Annual ACM Symposium on User Interface Software and Technology},
articleno = {48},
numpages = {3},
keywords = {Lipreading, Silent Speech Interface, Customization, One-shot Learning},
location = {Bend, OR, USA},
series = {UIST '22 Adjunct},

